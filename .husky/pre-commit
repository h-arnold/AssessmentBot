#!/usr/bin/env sh

# Format staged JavaScript and JSON files with Prettier, add them back to the commit,
# then run ESLint --fix. This keeps formatting consistent for committed files.

STAGED_FILES_BEFORE=$(git diff --cached --name-only --diff-filter=ACM)

# Synchronise Apps Script manifests and trigger scopes only when related files are staged.
if echo "$STAGED_FILES_BEFORE" | grep -Eq "^(src/backend/appsscript.json|src/AdminSheet/appsscript.json|src/AssessmentRecordTemplate/appsscript.json|src/AdminSheet/Utils/TriggerController.js|scripts/sync-appsscript.js)$"; then
  echo "Synchronising Apps Script configuration."
  node scripts/sync-appsscript.js
  git add src/backend/appsscript.json src/AdminSheet/appsscript.json src/AssessmentRecordTemplate/appsscript.json src/AdminSheet/Utils/TriggerController.js
fi

# Get list of staged files, excluding deprecated legacy areas from formatter runs.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(js|json|md)$" | grep -Ev "^src/(AdminSheet|AssessmentRecordTemplate)/" || true)

if [ -n "$STAGED_FILES" ]; then
	echo "Running Prettier on staged files:"
	echo "$STAGED_FILES"
	# Run Prettier (uses local install if available, otherwise npx)
	if command -v npx >/dev/null 2>&1; then
		npx prettier --write $STAGED_FILES
	else
		prettier --write $STAGED_FILES
	fi

	# Add any changes made by Prettier back to the commit
	git add $STAGED_FILES
fi

# Run ESLint autofix for remaining JS files
npm run lint:fix
