{
  "name": "AssessmentBot",
  "version": "0.7.7",
  "description": "**A tool designed by a Digital Technology and Computer Science teacher (and head of department) to simplify tracking and assessing the work of hundreds of students.**",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:all": "INCLUDE_LEGACY_UI_TESTS=true vitest run",
    "test:legacy-ui": "INCLUDE_LEGACY_UI_TESTS=true vitest run tests/ui/**/*.test.js tests/singletons/uiLazyProbe.test.js",
    "test:watch": "vitest",
    "lint": "eslint --config eslint.config.js src/AdminSheet/**/*.js src/backend/**/*.js",
    "lint:fix": "eslint --config eslint.config.js --fix src/AdminSheet/**/*.js src/backend/**/*.js",
    "vendor:beercss": "node scripts/vendor-beercss.js",
    "prepare": "husky install",
    "format": "prettier --write \"src/**/*.{js,json,md}\" \"**/*.{json,md}\"",
    "frontend:dev": "npm --prefix src/frontend run dev",
    "frontend:build": "npm --prefix src/frontend run build",
    "frontend:lint": "npm --prefix src/frontend run lint",
    "frontend:test": "npm --prefix src/frontend run test",
    "frontend:test:watch": "npm --prefix src/frontend run test:watch",
    "frontend:test:e2e": "npm --prefix src/frontend run test:e2e",
    "builder:compile": "tsc -p scripts/builder/tsconfig.json",
    "builder:run": "node scripts/builder/dist/build-gas-bundle.js",
    "builder:build": "npm run builder:compile && npm run builder:run --",
    "builder:build:dev": "npm run builder:compile && npm run builder:run -- --frontend-mode=dev",
    "builder:build:prod": "npm run builder:compile && npm run builder:run -- --frontend-mode=production",
    "builder:test": "vitest run --config scripts/builder/vitest.config.ts",
    "builder:lint": "eslint --config scripts/builder/eslint.config.js scripts/builder/src/**/*.ts",
    "builder:ci": "npm run builder:lint && npm run builder:test && npm run builder:build:prod"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.39.2",
    "eslint-plugin-googleappsscript": "^1.0.5",
    "eslint-plugin-jsdoc": "^62.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@google/clasp": "^3.1.3",
    "beercss": "^4.0.1"
  }
}
