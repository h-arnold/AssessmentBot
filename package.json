{
  "name": "AssessmentBot",
  "version": "0.7.8",
  "description": "**A tool designed by a Digital Technology and Computer Science teacher (and head of department) to simplify tracking and assessing the work of hundreds of students.**",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config eslint.config.js src/**/*.js",
    "lint:fix": "eslint --config eslint.config.js --fix src/**/*.js",
    "vendor:beercss": "node scripts/vendor-beercss.js",
    "prepare": "husky install",
    "format": "prettier --write \"src/**/*.{js,json,md}\" \"**/*.{json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-plugin-googleappsscript": "^1.0.5",
    "eslint-plugin-jsdoc": "^62.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@google/clasp": "^3.2.0",
    "@google/gemini-cli": "^0.26.0",
    "beercss": "^4.0.1"
  }
}
